---
/*
  Header — the wordmark and navigation shown at the top of every page.
  The nav links come from src/config.ts (edit them there, not here).
  The current page's link is highlighted automatically.
*/
import { site } from "../config";

// Astro.url.pathname is the path of the current page, e.g. "/about".
// We use it to mark the active nav link.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="border-b border-black/5">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-5">
    <!-- Wordmark links back to the home page. -->
    <a href="/" class="font-serif text-xl font-semibold text-navy">
      {site.name}
    </a>

    <nav class="flex items-center gap-6 text-sm">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors hover:text-blue",
              isActive(item.href) ? "text-blue" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <!-- Small Subscribe button, always visible in the header. -->
      <a
        href={site.substackUrl}
        class="rounded-md bg-blue px-3.5 py-1.5 font-medium text-white transition-colors hover:bg-navy"
      >
        Subscribe
      </a>
    </nav>
  </div>
</header>
