---
/*
  Header — the wordmark and navigation shown at the top of every page.
  The nav links come from src/config.ts (edit them there, not here).
  The current page's link is highlighted automatically.
*/
import { site } from "../config";

// Astro.url.pathname is the path of the current page, e.g. "/about".
// We use it to mark the active nav link.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="border-b border-navy/10">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start gap-3 px-6 py-5 sm:flex-row sm:items-center sm:justify-between sm:gap-4"
  >
    <!-- Wordmark (nameplate) links back to the home page. -->
    <a
      href="/"
      style="font-family: var(--font-display)"
      class="whitespace-nowrap text-2xl text-navy sm:text-3xl"
    >
      {site.name}
    </a>

    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm sm:gap-x-6">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors hover:text-blue",
              isActive(item.href) ? "text-blue" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <!-- Quiet outline Subscribe button (fills navy on hover). The bold, solid
           call-to-action lives on the home page hero instead. -->
      <a
        href={site.substackUrl}
        class="rounded-md border border-navy px-3.5 py-1.5 font-medium text-navy transition-colors hover:bg-navy hover:text-white"
      >
        Subscribe
      </a>
    </nav>
  </div>
</header>
