---
/*
  Footer — shown at the bottom of every page.
  Pulls the site name, tagline, and Substack link from src/config.ts.
*/
import { site } from "../config";

// Astro runs on the server, so we can compute the current year at build time.
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-navy/10">
  <div class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-12 text-sm text-muted">
    <p class="dateline">A weekly field report</p>
    <p style="font-family: var(--font-display)" class="text-xl text-navy">
      {site.name}
    </p>
    <p>{site.tagline}</p>
    <p class="mt-2">
      <a href={site.substackUrl} class="text-blue hover:underline">
        Read & subscribe on Substack &rarr;
      </a>
    </p>

    <!-- Page links (pulled from src/config.ts, same as the header). -->
    <nav class="mt-3 flex gap-5">
      {
        site.nav.map((item) => (
          <a href={item.href} class="transition-colors hover:text-blue">
            {item.label}
          </a>
        ))
      }
    </nav>

    <p class="mt-4 text-xs text-muted/80">
      &copy; {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
