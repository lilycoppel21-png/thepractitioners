---
/*
  Jobs page  (lives at  /jobs  )
  ------------------------------
  A VISUAL PLACEHOLDER only — no real applications or backend yet. It shows where the
  site is heading. Edit the example listings in the `jobs` array below. When you're ready
  to make it real, each listing can gain an `href` to an application page.
*/
import BaseLayout from "../layouts/BaseLayout.astro";

// Example listings (placeholders). Edit freely.
const jobs = [
  {
    title: "AI Programme Lead",
    org: "Refugee Action Network",
    location: "London · Hybrid",
    type: "Full-time",
    blurb:
      "Help frontline teams adopt AI responsibly across casework and triage, with strong guardrails for sensitive data.",
  },
  {
    title: "Data & Impact Analyst",
    org: "Coastal Conservation Trust",
    location: "Remote (UK)",
    type: "Full-time",
    blurb:
      "Turn messy field data into clear decisions, with a light, careful touch of automation.",
  },
  {
    title: "AI Tools Researcher",
    org: "The Practitioners",
    location: "Remote",
    type: "Part-time · Volunteer",
    blurb:
      "Help us test and review AI tools for the nonprofit sector, and write up honest, plain-language findings.",
  },
];
---

<BaseLayout title="Jobs — The Practitioners">
  <section class="mx-auto max-w-5xl px-6 pt-12 pb-8 md:pt-16">
    <p class="dateline">Jobs board —</p>
    <h1 class="page-title mt-3">Jobs</h1>
    <p class="lead mt-5 max-w-2xl">
      Mission-driven roles working with AI across the social impact sector.
    </p>

    <!-- Clear "coming soon" state -->
    <div class="mt-8 rounded-lg border border-navy/10 bg-mist p-5">
      <p class="dateline">Coming soon —</p>
      <p class="mt-2 max-w-2xl text-base text-ink">
        We're building a job board for mission-driven roles in AI and social impact. The
        listings below are examples of what's coming — applications aren't open yet.
      </p>
    </div>

    <!-- Example listings -->
    <div class="mt-10 space-y-5">
      {
        jobs.map((job) => (
          <article class="rounded-lg border border-navy/10 p-6 transition-colors hover:border-navy/25">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h2 class="font-display text-xl leading-snug text-navy">{job.title}</h2>
                <p class="mt-1 text-sm text-muted">
                  {job.org} · {job.location}
                </p>
              </div>
              <span class="dateline whitespace-nowrap rounded-full border border-navy/15 px-3 py-1 text-[0.7rem] text-muted">
                {job.type}
              </span>
            </div>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink/90">{job.blurb}</p>
            <span
              class="mt-4 inline-block rounded-md border border-navy/20 px-4 py-2 text-sm text-muted"
              aria-disabled="true"
            >
              Applications open soon
            </span>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
