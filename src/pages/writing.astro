---
/*
  Writing page  (lives at  /writing  )
  ------------------------------------
  For now this points readers to the Substack, where all the writing lives.

  LATER — pulling posts in automatically:
  Substack publishes an RSS feed at  <your-substack-url>/feed . When you're ready to
  list recent posts here, you can fetch that feed at build time and loop over it.
  A rough sketch (uncomment and adapt when ready):

      // const res = await fetch(`${site.substackUrl}/feed`);
      // const xml = await res.text();
      // ...parse the <item> entries (title, link, pubDate) and map over them below.

  Alternatively, Astro "Content Collections" let you write posts as local Markdown
  files in src/content/ and list them here.
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
---

<BaseLayout title="Writing — The Practitioners">
  <section class="mx-auto max-w-2xl px-6 pt-16 pb-8 md:pt-24">
    <p class="dateline">From the archive —</p>
    <h1 class="page-title mt-4">Writing</h1>

    <p class="lead mt-6">
      The Practitioners is published weekly on Substack.
    </p>

    <p class="mt-4 text-muted">
      That's where every issue lives, and where you can read the archive and subscribe
      to get new pieces by email.
    </p>

    <div class="mt-8">
      <a
        href={site.substackUrl}
        class="inline-block rounded-md bg-blue px-6 py-3 font-medium text-white transition-colors hover:bg-navy"
      >
        Read every issue on Substack
      </a>
    </div>

    <!-- Placeholder for the future post list (see the comment at the top of this file). -->
    <div class="mt-16 border-t border-navy/10 pt-8">
      <p class="dateline">Coming soon —</p>
      <p class="mt-2 text-base text-muted">
        Recent issues will appear here automatically, pulled in from the newsletter.
      </p>
    </div>
  </section>
</BaseLayout>
